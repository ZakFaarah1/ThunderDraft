# Python-generated bytecode and cache folders.
__pycache__/
*.py[cod]

# ThunderDraft runtime NFL cache.
backend/data/cache/*
!backend/data/cache/.gitkeep

# Frontend dependencies and build output.
frontend/node_modules/
frontend/dist/

# Local environment files.
.env
.env.*
!.env.example

# Local persistent ThunderDraft databases.
backend/data/*.sqlite3*
